rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/projects
    // Document ID: projectId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - githubRepo: string (optional)
    //   - githubToken: string (optional)
    //   - gcm: map (required)
    //   - lastUpdated: string (optional)
    //
    // Collection: /users/{userId}/projects/{projectId}/notes
    // Document ID: noteId
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - folder: string (required)
    //   - content: string (required)
    //   - summary: string (required)
    //   - parentNoteId: string (optional)
    //   - relatedNoteIds: list (optional)
    //   - status: string (required)
    //   - githubLink: string (optional)
    //   - lastUpdated: string (optional)
    //   - yamlMetadata: string (required)
    //   - isMainFeature: bool (optional)
    //
    // Collection: /users/{userId}/projects/{projectId}/chats
    // Document ID: chatId
    // Fields:
    //   - id: string (required)
    //   - role: string (required, user/model)
    //   - content: string (required)
    //   - createdAt: string (required)
    //   - expiresAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "kwoncho1001@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProject(data) {
      return (!('id' in data) || data.id is string) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 1000)) &&
             (!('gcm' in data) || data.gcm is map) &&
             (!('githubRepo' in data) || data.githubRepo is string) &&
             (!('githubToken' in data) || data.githubToken is string) &&
             (!('lastUpdated' in data) || data.lastUpdated is string);
    }

    function isValidNote(data) {
      return (!('id' in data) || data.id is string) &&
             (!('title' in data) || (data.title is string && data.title.size() <= 2000)) &&
             (!('folder' in data) || (data.folder is string && data.folder.size() <= 2000)) &&
             (!('content' in data) || (data.content is string && data.content.size() <= 1000000)) &&
             (!('summary' in data) || (data.summary is string && data.summary.size() <= 50000)) &&
             (!('noteType' in data) || data.noteType == null || data.noteType in ['Epic', 'Feature', 'Task', 'Reference']) &&
             (!('status' in data) || data.status is string) &&
             (!('yamlMetadata' in data) || (data.yamlMetadata is string && data.yamlMetadata.size() <= 100000)) &&
             (!('parentNoteId' in data) || data.parentNoteId == null || data.parentNoteId is string) &&
             (!('parentNoteIds' in data) || data.parentNoteIds == null || data.parentNoteIds is list) &&
             (!('childNoteIds' in data) || data.childNoteIds == null || data.childNoteIds is list) &&
             (!('relatedNoteIds' in data) || data.relatedNoteIds == null || data.relatedNoteIds is list) &&
             (!('githubLink' in data) || data.githubLink == null || data.githubLink is string) &&
             (!('lastUpdated' in data) || data.lastUpdated == null || data.lastUpdated is string) &&
             (!('isMainFeature' in data) || data.isMainFeature == null || data.isMainFeature is bool) &&
             (!('conflictInfo' in data) || data.conflictInfo == null || data.conflictInfo is map) &&
             (!('consistencyConflict' in data) || data.consistencyConflict == null || data.consistencyConflict is map);
    }

    function isValidChatMessage(data) {
      return data.id is string &&
             data.role in ['user', 'model'] &&
             data.content is string &&
             data.content.size() <= 100000 &&
             data.createdAt is string &&
             data.expiresAt is timestamp;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /projects/{projectId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidProject(request.resource.data);
        allow update: if (isOwner(userId) || isAdmin()) && isValidProject(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();

        match /notes/{noteId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) || isAdmin()) && isValidNote(request.resource.data);
          allow update: if (isOwner(userId) || isAdmin()) && isValidNote(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }

        match /syncLogs/{logId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }

        match /chats/{chatId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) || isAdmin()) && isValidChatMessage(request.resource.data);
          allow update: if (isOwner(userId) || isAdmin()) && isValidChatMessage(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }
    }
  }
}
