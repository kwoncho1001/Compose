rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/projects
    // Document ID: projectId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - githubRepo: string (optional)
    //   - githubToken: string (optional)
    //   - gcm: map (required)
    //   - lastUpdated: string (optional)
    //
    // Collection: /users/{userId}/projects/{projectId}/notes
    // Document ID: noteId
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - folder: string (required)
    //   - content: string (required)
    //   - summary: string (required)
    //   - parentNoteId: string (optional)
    //   - relatedNoteIds: list (optional)
    //   - status: string (required)
    //   - githubLink: string (optional)
    //   - lastUpdated: string (optional)
    //   - yamlMetadata: string (required)
    //   - isMainFeature: bool (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "kwoncho1001@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidProject(data) {
      return data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.gcm is map &&
             (!('githubRepo' in data) || data.githubRepo is string) &&
             (!('githubToken' in data) || data.githubToken is string) &&
             (!('lastUpdated' in data) || data.lastUpdated is string);
    }

    function isValidNote(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.folder is string && data.folder.size() > 0 && data.folder.size() <= 500 &&
             data.content is string && data.content.size() <= 200000 &&
             data.summary is string && data.summary.size() <= 5000 &&
             data.status is string &&
             data.yamlMetadata is string && data.yamlMetadata.size() <= 20000 &&
             (!('parentNoteId' in data) || data.parentNoteId == null || data.parentNoteId is string) &&
             (!('relatedNoteIds' in data) || data.relatedNoteIds == null || data.relatedNoteIds is list) &&
             (!('githubLink' in data) || data.githubLink == null || data.githubLink is string) &&
             (!('lastUpdated' in data) || data.lastUpdated == null || data.lastUpdated is string) &&
             (!('isMainFeature' in data) || data.isMainFeature == null || data.isMainFeature is bool) &&
             (!('conflictInfo' in data) || data.conflictInfo == null || data.conflictInfo is map) &&
             (!('consistencyConflict' in data) || data.consistencyConflict == null || data.consistencyConflict is map);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /projects/{projectId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) || isAdmin()) && isValidProject(request.resource.data);
        allow update: if (isOwner(userId) || isAdmin()) && isValidProject(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();

        match /notes/{noteId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if (isOwner(userId) || isAdmin()) && isValidNote(request.resource.data);
          allow update: if (isOwner(userId) || isAdmin()) && isValidNote(request.resource.data);
          allow delete: if isOwner(userId) || isAdmin();
        }
      }
    }
  }
}
